# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# 虚拟环境
.venv/
venv/
env/
ENV/

# 测试 / 覆盖率 / 缓存
.pytest_cache/
.cache/
.coverage
.coverage.*
htmlcov/
.tox/
